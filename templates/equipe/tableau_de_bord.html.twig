{% extends 'base.html.twig' %}

{% block title %}Tableau de bord — UrbanQuest{% endblock %}

{% block body %}
    <div class="flex min-h-[calc(100vh-8rem)] flex-col items-center justify-center gap-8 px-6 py-12 text-center">
        <div class="w-full max-w-sm rounded-2xl border border-[#c2b7a2] bg-[#fff6dd] p-8 shadow-xl shadow-black/10">
            <p class="text-sm font-semibold uppercase tracking-widest text-[#9f8121]" style="font-family: var(--player-font-heading);">UrbanQuest</p>
            <h1 class="mt-2 text-2xl font-extrabold text-[#2a2015]" style="font-family: var(--player-font-heading);">
                Connecté en tant que {{ joueur.pseudo }} — équipe {{ joueur.equipe.nom }}
            </h1>
            <div id="dashboard-score"{% if tempsReelDisponible %} {{ turbo_stream_listen('equipe/' ~ joueur.equipe.id, null, { withCredentials: true }) }}{% endif %}>
                {% include 'equipe/_dashboard_score.html.twig' %}
            </div>

            <a
                href="{{ path('app_jeu_index') }}"
                class="mt-8 inline-flex w-full items-center justify-center rounded-xl bg-[#b5651d] px-6 py-3 text-base font-semibold text-white shadow-lg shadow-[#b5651d]/30 transition hover:bg-[#dc8638] active:scale-[0.98]"
            >
                Jouer
            </a>

            <a
                href="{{ path('app_classement_index') }}"
                class="mt-3 inline-flex w-full items-center justify-center rounded-xl border border-[#dbd0ba] px-6 py-3 text-base font-semibold text-[#8f8573] transition hover:border-[#8f8573] hover:text-[#2a2015] active:scale-[0.98]"
            >
                Voir le classement
            </a>

            <a
                href="{{ path('app_logout') }}"
                class="mt-3 inline-flex w-full items-center justify-center rounded-xl border border-[#dbd0ba] px-6 py-3 text-base font-semibold text-[#8f8573] transition hover:border-[#8f8573] hover:text-[#2a2015] active:scale-[0.98]"
            >
                Se déconnecter
            </a>
        </div>
    </div>
{% endblock %}