{% extends 'base.html.twig' %}

{% block title %}Classement — UrbanQuest{% endblock %}

{% block body %}
    <div class="mx-auto flex max-w-screen-sm flex-col gap-6 px-4 py-8">
        <div class="text-center">
            <p class="text-sm font-semibold uppercase tracking-widest text-[#9f8121]" style="font-family: var(--player-font-heading);">Classement</p>
            <h1 class="mt-2 text-2xl font-extrabold text-[#2a2015]" style="font-family: var(--player-font-heading);">Toutes les équipes</h1>
        </div>

        <div id="classement-fragment" {{ turbo_stream_listen('classement') }}>
            {% include 'classement/_fragment.html.twig' %}
        </div>

        <div>
            <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-[#9f8121]" style="font-family: var(--player-font-heading);">Activité récente</p>
            <div id="activite-fragment" {{ turbo_stream_listen('activite') }}>
                {% include 'activite/_fragment.html.twig' %}
            </div>
        </div>

        <a
            href="{{ path('app_equipe_dashboard') }}"
            class="mt-2 inline-flex w-full items-center justify-center rounded-xl border border-[#dbd0ba] px-6 py-3 text-base font-semibold text-[#8f8573] transition hover:border-[#8f8573] hover:text-[#2a2015] active:scale-[0.98]"
        >
            Retour au tableau de bord
        </a>
    </div>
{% endblock %}