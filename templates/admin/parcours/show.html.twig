{% extends 'base.html.twig' %}

{% block title %}Parcours{% endblock %}

{% block body %}
    <h1>Parcours</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ parcour.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ parcour.nom }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ parcour.description }}</td>
            </tr>
            <tr>
                <th>Ville</th>
                <td>{{ parcour.ville }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ parcour.statut }}</td>
            </tr>
            <tr>
                <th>DateCreation</th>
                <td>{{ parcour.dateCreation ? parcour.dateCreation|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>EstArchive</th>
                <td>{{ parcour.estArchive ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_parcours_index') }}">back to list</a>

    <a href="{{ path('app_parcours_edit', {'id': parcour.id}) }}">edit</a>

    {{ include('parcours/_delete_form.html.twig') }}
{% endblock %}
