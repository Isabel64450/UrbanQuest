{% extends 'base.html.twig' %}

{% block title %}Rejoindre une équipe — UrbanQuest{% endblock %}

{% block body %}
    <div class="flex min-h-[calc(100vh-8rem)] flex-col items-center justify-center gap-8 px-6 py-12">
        <div class="w-full max-w-sm rounded-2xl border border-[#c2b7a2] bg-[#fff6dd] p-8 shadow-xl shadow-black/10">
            <p class="text-sm font-semibold uppercase tracking-widest text-[#9f8121]" style="font-family: var(--player-font-heading);">UrbanQuest</p>
            <h1 class="mt-2 text-2xl font-extrabold text-[#2a2015]" style="font-family: var(--player-font-heading);">Rejoindre une équipe</h1>
            <p class="mt-3 text-sm text-[#766b5c]">
                Saisissez le code d'accès communiqué par l'organisateur de votre parcours.
            </p>

            {{ form_start(form, {
                attr: { class: 'mt-6 flex flex-col gap-4' }
            }) }}
                <div>
                    {{ form_label(form.codeAcces, null, { label_attr: { class: 'block text-sm font-medium text-[#8f8573]', style: 'font-family: var(--player-font-heading);' } }) }}
                    {{ form_widget(form.codeAcces, {
                        attr: {
                            class: 'mt-2 w-full rounded-xl border border-[#dbd0ba] bg-[#f4e9d1] px-4 py-3 text-base text-[#2a2015] placeholder-[#766b5c] focus:border-[#b5651d] focus:outline-none focus:ring-2 focus:ring-[#b5651d]/40'
                        }
                    }) }}
                    {{ form_errors(form.codeAcces) }}
                </div>

                <button
                    type="submit"
                    class="mt-2 inline-flex w-full items-center justify-center rounded-xl bg-[#b5651d] px-6 py-3 text-base font-semibold text-white shadow-lg shadow-[#b5651d]/30 transition hover:bg-[#dc8638] active:scale-[0.98]"
                >
                    Continuer
                </button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}